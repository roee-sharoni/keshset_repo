# Copy this file to .env and fill in real values.
# Generate FERNET_KEY:  python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Generate API_SECRET_KEY: openssl rand -hex 32

AIRFLOW_UID=50000

# ── Local passwords ───────────────────────────────────────────────────────────
AIRFLOW_WWW_USER_USERNAME=admin
AIRFLOW_WWW_USER_PASSWORD=<strong-password>
MYSQL_ROOT_PASSWORD=<strong-root-password>
MYSQL_PASSWORD=<strong-password>

# ── Encryption keys (generate fresh values — never reuse between environments) ─
FERNET_KEY=<generate-with-python>
API_SECRET_KEY=<generate-with-openssl>

# ── Snowflake connections ─────────────────────────────────────────────────────
AIRFLOW_CONN_SNOWFLAKE_BYS=snowflake://user:pass@account/BYS_DWH/ANALYTICS?warehouse=WH&role=ROLE
AIRFLOW_CONN_SNOWFLAKE_UGC=snowflake://user:pass@account/UGC_DWH/ANALYTICS?warehouse=WH&role=ROLE

# ── BigQuery (drop gcp-sa.json into ./config/ when ready) ────────────────────
AIRFLOW_CONN_BIGQUERY_PROD=google-cloud-platform://?extra__google_cloud_platform__key_path=%2Fopt%2Fairflow%2Fconfig%2Fgcp-sa.json&extra__google_cloud_platform__project=my-project

# ── Slack incoming webhook ────────────────────────────────────────────────────
AIRFLOW_CONN_SLACK_ALERTS=slackwebhook://hooks.slack.com/services/T000/B000/XXXX
